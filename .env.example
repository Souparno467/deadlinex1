# PORT: Local dev server port. Defaults to 5173.
# PORT=5173

# GROQ_API_KEY: Required for AI features (Chief of Staff, risk analysis, voice commands).
# Get your key at https://console.groq.com/keys
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# GROQ_MODEL: Optional. Defaults to llama-3.3-70b-versatile.
# GROQ_MODEL="llama-3.3-70b-versatile"

# APP_URL: The URL where this app is hosted (OAuth callbacks, self-referential links).
APP_URL="MY_APP_URL"
